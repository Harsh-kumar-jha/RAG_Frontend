# API Configuration
# NOTE: The frontend uses NEXT_PUBLIC_API_URL in priority. If not set, it will use
# NEXT_PUBLIC_API_BASE_URL and append /api to it.

# Option 1: Set the API base URL without /api suffix
# The frontend will automatically append /api to make requests to /api/documents, /api/chat, etc.
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000

# Option 2: Set the full API URL with /api suffix (takes precedence over NEXT_PUBLIC_API_BASE_URL)
NEXT_PUBLIC_API_URL=http://localhost:5000/api

# Default fallback (if both above are not set):
# http://localhost:5000/api


